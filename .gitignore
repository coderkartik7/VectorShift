# OS junk
.DS_Store

# Node (covers potential root-level frontend builds)
node_modules/
/dist/
/build/

# Python
__pycache__/
*.py[cod]
*.pyd
*$py.class

# Virtual environments
.venv/
venv/

# Python tooling caches
.mypy_cache/
.ruff_cache/
.pytest_cache/
.tox/

# Env files (backend/frontend may use these)
.env
.env.*

# IDE/editor
.vscode/
.idea/
*.swp
*.swo

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
*.log

# TypeScript build info (safe even if TS isn’t used)
*.tsbuildinfo

